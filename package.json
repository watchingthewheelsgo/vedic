{
  "name": "vedic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:backend:dev\" \"npm:client:dev\"",
    "dev:payments": "concurrently -k \"npm:backend:dev\" \"npm:client:dev\" \"npm:creem:webhook:tunnel\"",
    "client:dev": "vite --host 127.0.0.1",
    "creem:webhook:tunnel": "node scripts/dev-creem-webhook-tunnel.mjs",
    "backend:sync": "uv sync --project backend --all-groups",
    "backend:setup": "npm run backend:sync && npm run backend:ensure",
    "backend:ensure": "uv run --no-sync --project backend python scripts/setup-backend-runtime.py",
    "backend:config": "uv run --no-sync --project backend python scripts/check-startup-config.py",
    "backend:dev": "npm run backend:ensure && npm run backend:config && uv run --no-sync --project backend uvicorn app.main:app --host 127.0.0.1 --port 8787 --reload --reload-dir backend/app",
    "backend:format": "uv run --no-sync --project backend ruff format backend/app scripts backend/tests",
    "backend:format:check": "uv run --no-sync --project backend ruff format --check backend/app scripts backend/tests",
    "backend:lint": "uv run --no-sync --project backend ruff check backend/app scripts backend/tests",
    "backend:check": "uv run --no-sync --project backend python scripts/check-backend-runtime.py && uv run --no-sync --project backend python -m compileall backend/app scripts",
    "backend:typecheck": "pyright",
    "backend:test": "uv run --no-sync --project backend pytest backend/tests",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "frontend:lint": "eslint src scripts vite.config.ts",
    "report:export": "uv run --project backend python scripts/export-report.py",
    "report:pdf": "node scripts/render-report-pdf.mjs",
    "report:pdf:install": "playwright install chromium",
    "workflow:test": "node scripts/run-full-workflow.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "tsc --noEmit",
    "ci": "npm run format:check && npm run frontend:lint && npm run backend:format:check && npm run backend:lint && npm run check && npm run backend:sync && npm run backend:ensure && npm run backend:check && npm run backend:typecheck && npm run backend:test && npm run build"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.8",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.468.0",
    "playwright": "^1.61.1",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "pyright": "^1.1.411",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.0.0"
  }
}
